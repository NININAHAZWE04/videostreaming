# ============================================================
#  VideoStreaming Platform — Variables d'environnement Docker
#  Copier en .env et remplir les valeurs
# ============================================================

# ── Sécurité — OBLIGATOIRE à changer en production ──────────
ADMIN_SECRET=changez-moi-secret-admin-fort
JWT_SECRET=changez-moi-secret-jwt-64-caracteres-minimum-aleatoire

# ── Ports exposés (changer si conflits locaux) ───────────────
PORT_DIARY_RMI=12999
PORT_API_PUBLIC=18080
PORT_API_ADMIN=18081
PORT_H2_CONSOLE=18082
PORT_CLIENT_WEB=55173
PORT_ADMIN_WEB=55174

# ── Configuration DB ─────────────────────────────────────────
DB_PASSWORD=

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
